---
export const prerender = true

type Release = {
  tag_name: string
  html_url: string
  body: string
  draft: boolean
  prerelease: boolean
  published_at: string | null
}

type Section = {
  title: string
  items: string[]
}

type Entry = {
  tag: string
  url: string
  date: string
  sections: Section[]
}

function parse(body: string) {
  const sections: Section[] = []
  let section: Section | undefined

  for (const raw of body.split("\n")) {
    const line = raw.trim()
    if (!line) continue

    if (line.startsWith("## ")) {
      section = {
        title: line.slice(3).trim(),
        items: [],
      }
      sections.push(section)
      continue
    }

    if (!section) continue
    if (line.startsWith("- ")) {
      section.items.push(line.slice(2).trim())
    }
  }

  return sections.filter((section) => section.items.length > 0)
}

const response = await fetch("https://api.github.com/repos/teamslop/slopcode/releases?per_page=30", {
  headers: {
    Accept: "application/vnd.github.v3+json",
    "User-Agent": "SlopCode-Web",
  },
}).catch(() => undefined)

const data = response?.ok ? await response.json().catch(() => []) : []

const entries: Entry[] = Array.isArray(data)
  ? (data as Release[])
      .filter((release) => !release.draft)
      .filter((release) => !release.prerelease)
      .filter((release): release is Release & { published_at: string } => typeof release.published_at === "string")
      .map((release) => ({
        tag: release.tag_name,
        url: release.html_url,
        date: release.published_at,
        sections: parse(release.body || ""),
      }))
      .filter((entry) => entry.sections.length > 0)
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  : []

const date = (value: string) =>
  new Date(value).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  })
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Changelog | SlopCode</title>
    <meta name="description" content="SlopCode changelog and release notes." />
  </head>
  <body>
    <main>
      <a href="/">Back to docs</a>
      <h1>Changelog</h1>
      <p>Release notes published from <a href="https://github.com/teamslop/slopcode/releases">teamslop/slopcode</a>.</p>

      {entries.length === 0 ? (
        <p>No changelog entries are available right now.</p>
      ) : (
        entries.map((entry) => (
          <article>
            <header>
              <a href={entry.url} target="_blank" rel="noopener noreferrer">
                {entry.tag}
              </a>
              <time datetime={entry.date}>{date(entry.date)}</time>
            </header>

            {entry.sections.map((section) => (
              <section>
                <h2>{section.title}</h2>
                <ul>
                  {section.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            ))}
          </article>
        ))
      )}
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
  }

  body {
    margin: 0;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    background: #faf9f8;
    color: #171615;
  }

  @media (prefers-color-scheme: dark) {
    body {
      background: #0f0e0d;
      color: #ece9e6;
    }
  }

  main {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }

  a {
    color: inherit;
  }

  h1 {
    font-size: 2rem;
    margin: 0.75rem 0 0.5rem;
  }

  p {
    margin: 0;
    line-height: 1.6;
  }

  article {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(125, 120, 114, 0.35);
  }

  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  header a {
    font-weight: 700;
    text-decoration: none;
  }

  header a:hover {
    text-decoration: underline;
  }

  time {
    opacity: 0.72;
    font-size: 0.9rem;
  }

  h2 {
    font-size: 0.95rem;
    margin: 1rem 0 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.25rem;
  }

  li {
    line-height: 1.55;
  }

  @media (max-width: 40rem) {
    header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
