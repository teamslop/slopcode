{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["CI", "SLOPCODE_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "SLOPCODE_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "slopcode#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@slopcode-ai/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
